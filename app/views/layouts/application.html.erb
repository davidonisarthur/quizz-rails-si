<!DOCTYPE html>
<html>
  <head>
    <script>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <title><%= content_for(:title) || "Quizz Rails" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Quizz Rails">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-bg0 text-tx0 font-sans antialiased min-h-screen transition-colors duration-200">
    <nav class="fixed top-0 left-0 right-0 bg-bg1 border-b border-bg3 z-50 transition-colors duration-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center">
            <%= link_to "PrimoQuiz", root_path(locale: I18n.locale), class: "text-2xl font-bold text-accent" %>
          </div>
          
          <div class="flex items-center space-x-4">
            <%= link_to "Ranking", ranking_path(locale: I18n.locale), class: "text-tx1 hover:text-accent font-semibold transition" %>
            <%= link_to t('about'), about_path(locale: I18n.locale), class: "text-tx1 hover:text-accent font-semibold transition" %>
            
            <% if current_user %>
              <%= link_to current_user.name, profile_path(locale: I18n.locale), class: "text-tx1 hover:text-accent font-semibold transition" %>
              <%= button_to "Sair", session_path(locale: I18n.locale), method: :delete, class: "text-tx1 hover:text-red font-semibold transition cursor-pointer" %>
            <% else %>
              <%= link_to "Entrar", new_session_path(locale: I18n.locale), class: "text-tx1 hover:text-accent font-semibold transition" %>
            <% end %>

            <!-- LIBRAS Mode Toggle -->
            <%= button_to toggle_libras_mode_path(locale: I18n.locale), 
                           method: :post,
                           class: "flex items-center space-x-1.5 px-3 py-1.5 rounded-full text-xs font-semibold border transition #{libras_mode_enabled? ? 'bg-amber-100/80 dark:bg-amber-950/40 text-amber-800 dark:text-amber-300 border-amber-300 dark:border-amber-800/60' : 'bg-gray-50 dark:bg-gray-800 text-gray-500 dark:text-gray-400 border-gray-200 dark:border-gray-700/50 hover:bg-gray-100 dark:hover:bg-gray-700/50'}",
                           aria: { label: t('quiz.libras_mode') } do %>
              <span class="w-2 h-2 rounded-full <%= libras_mode_enabled? ? 'bg-amber-500 animate-pulse' : 'bg-gray-400' %>"></span>
              <span><%= t('quiz.libras_mode') %></span>
            <% end %>

            <!-- Theme Toggle Button -->
            <button type="button"
                    data-controller="theme"
                    data-action="click->theme#toggle"
                    class="flex items-center space-x-1.5 px-3 py-1.5 rounded-full text-xs font-semibold border transition bg-gray-50 dark:bg-gray-800 text-gray-500 dark:text-gray-400 border-gray-200 dark:border-gray-700/50 hover:bg-gray-150 dark:hover:bg-gray-700/80 cursor-pointer"
                    aria-label="Toggle Theme">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 hidden dark:inline">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 inline dark:hidden">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
              </svg>
              <span><%= I18n.locale == :en ? "Theme" : "Tema" %></span>
            </button>

            <div class="flex items-center space-x-2 border-l pl-4 border-bg3">
              <%= link_to "PT", { locale: 'pt-BR' }, class: "text-xs font-bold #{I18n.locale == :'pt-BR' ? 'text-accent' : 'text-tx2'}" %>
              <%= link_to "EN", { locale: 'en' }, class: "text-xs font-bold #{I18n.locale == :en ? 'text-accent' : 'text-tx2'}" %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main class="container mx-auto mt-24 px-5">
      <%= yield %>
    </main>
  </body>
</html>
