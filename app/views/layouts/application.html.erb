<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Quizz Rails" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Quizz Rails">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="fixed top-0 left-0 right-0 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center">
            <%= link_to "PrimoQuiz", root_path(locale: I18n.locale), class: "text-2xl font-bold text-indigo-600" %>
          </div>
          
          <div class="flex items-center space-x-4">
            <%= link_to "Ranking", ranking_path(locale: I18n.locale), class: "text-gray-600 dark:text-gray-300 hover:text-indigo-600" %>
            
            <% if current_user %>
              <%= link_to current_user.name, profile_path(locale: I18n.locale), class: "text-gray-600 dark:text-gray-300 hover:text-indigo-600" %>
              <%= button_to "Sair", session_path(locale: I18n.locale), method: :delete, class: "text-gray-600 dark:text-gray-300 hover:text-red-600" %>
            <% else %>
              <%= link_to "Entrar", new_session_path(locale: I18n.locale), class: "text-gray-600 dark:text-gray-300 hover:text-indigo-600" %>
            <% end %>

            <div class="flex items-center space-x-2 border-l pl-4 border-gray-200 dark:border-gray-700">
              <%= link_to "PT", { locale: 'pt-BR' }, class: "text-xs font-bold #{I18n.locale == :'pt-BR' ? 'text-indigo-600' : 'text-gray-400'}" %>
              <%= link_to "EN", { locale: 'en' }, class: "text-xs font-bold #{I18n.locale == :en ? 'text-indigo-600' : 'text-gray-400'}" %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main class="container mx-auto mt-24 px-5">
      <%= yield %>
    </main>
  </body>
</html>
