<div class="max-w-md mx-auto py-10 px-4">
  <h2 class="text-3xl font-bold mb-6 text-center">Entrar</h2>

  <%= form_with url: session_path(locale: I18n.locale), class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email, required: true, class: "w-full p-2 rounded border border-gray-300 dark:bg-gray-800 dark:border-gray-700" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password, required: true, class: "w-full p-2 rounded border border-gray-300 dark:bg-gray-800 dark:border-gray-700" %>
    </div>

    <%= f.submit "Entrar", class: "w-full bg-indigo-600 text-white py-2 rounded font-bold hover:bg-indigo-700 transition cursor-pointer" %>
  <% end %>

  <p class="mt-4 text-center text-sm text-gray-600 dark:text-gray-400">
    Não tem conta? <%= link_to "Cadastre-se", new_user_path(locale: I18n.locale), class: "text-indigo-600 hover:underline" %>
  </p>
</div>
