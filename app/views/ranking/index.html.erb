<div class="max-w-2xl mx-auto py-10 px-4">
  <h2 class="text-3xl font-bold mb-8 text-center"><%= t('ranking.title') %></h2>

  <div class="bg-bg2 rounded-xl shadow-md overflow-hidden border border-bg3">
    <table class="w-full text-left">
      <thead class="bg-bg3">
        <tr>
          <th class="px-6 py-3 text-xs font-bold text-tx1 uppercase">Posição</th>
          <th class="px-6 py-3 text-xs font-bold text-tx1 uppercase">Nome</th>
          <th class="px-6 py-3 text-xs font-bold text-tx1 uppercase"><%= t('ranking.score') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-bg3">
        <% @ranking.each_with_index do |user, index| %>
          <tr class="hover:bg-bg3/25 transition">
            <td class="px-6 py-4 font-bold text-tx2">#<%= index + 1 %></td>
            <td class="px-6 py-4 font-medium"><%= user.name %></td>
            <td class="px-6 py-4 font-bold text-accent"><%= user.total_score %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
