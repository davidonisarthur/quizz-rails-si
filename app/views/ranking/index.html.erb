<div class="max-w-2xl mx-auto py-10 px-4">
  <h2 class="text-3xl font-bold mb-8 text-center"><%= t('ranking.title') %></h2>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm overflow-hidden border border-gray-200 dark:border-gray-700">
    <table class="w-full text-left">
      <thead class="bg-gray-50 dark:bg-gray-700">
        <tr>
          <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase">Posição</th>
          <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase">Nome</th>
          <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase"><%= t('ranking.score') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
        <% @ranking.each_with_index do |user, index| %>
          <tr>
            <td class="px-6 py-4 font-bold text-gray-400">#<%= index + 1 %></td>
            <td class="px-6 py-4"><%= user.name %></td>
            <td class="px-6 py-4 font-semibold text-indigo-600"><%= user.total_score %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
