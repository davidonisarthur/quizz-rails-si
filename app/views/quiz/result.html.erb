<div class="max-w-2xl mx-auto py-10 px-4 text-center">
  <h2 class="text-4xl font-extrabold mb-4">Quiz Finalizado!</h2>
  <p class="text-2xl mb-8">
    Sua pontuação: <span class="font-extrabold text-accent"><%= @score %> / <%= @total %></span>
  </p>

  <div class="space-x-4">
    <%= link_to 'Voltar ao início', root_path(locale: I18n.locale), class: "inline-block bg-bg3 text-tx1 px-6 py-2.5 rounded-xl hover:brightness-95 font-semibold transition duration-200" %>
    <%= link_to 'Tentar novamente', play_quiz_module_path(@module.slug, locale: I18n.locale), class: "inline-block bg-accent text-white px-6 py-2.5 rounded-xl hover:brightness-110 font-semibold shadow transition duration-200" %>
  </div>
</div>
