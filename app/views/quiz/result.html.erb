<div class="max-w-2xl mx-auto py-10 px-4 text-center">
  <h2 class="text-4xl font-bold mb-4">Quiz Finalizado!</h2>
  <p class="text-2xl mb-8">
    Sua pontuação: <span class="font-bold text-indigo-600"><%= @score %> / <%= @total %></span>
  </p>

  <div class="space-x-4">
    <%= link_to 'Voltar ao início', root_path(locale: I18n.locale), class: "inline-block bg-gray-200 text-gray-800 px-6 py-2 rounded hover:bg-gray-300 transition" %>
    <%= link_to 'Tentar novamente', play_quiz_module_path(@module.slug, locale: I18n.locale), class: "inline-block bg-indigo-600 text-white px-6 py-2 rounded hover:bg-indigo-700 transition" %>
  </div>
</div>
