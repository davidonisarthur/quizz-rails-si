<div class="max-w-2xl mx-auto py-10 px-4">
  <%= turbo_frame_tag "quiz_content" do %>
    <div class="mb-8">
      <h2 class="text-2xl font-bold mb-4">
        <%= I18n.locale == :en ? @question.body_en : @question.body_pt %>
      </h2>
      
      <% if @question.context_pt.present? %>
        <p class="text-gray-600 dark:text-gray-400 italic mb-6">
          <%= I18n.locale == :en ? @question.context_en : @question.context_pt %>
        </p>
      <% end %>
    </div>

    <div class="space-y-4">
      <% @options.each_with_index do |option, index| %>
        <%= button_to answer_quiz_module_path(@module.slug, locale: I18n.locale, option_index: index), 
                      method: :post,
                      class: "w-full text-left p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition" do %>
          <span class="font-semibold mr-2"><%= (index + 65).chr %>)</span>
          <%= I18n.locale == :en ? option.text_en : option.text_pt %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
