<div class="max-w-2xl mx-auto py-10 px-4">
  <%= turbo_frame_tag "quiz_content" do %>
    <!-- Barra de progresso -->
    <div class="mb-8">
      <div class="flex justify-between items-center text-sm text-gray-500 dark:text-gray-400 mb-2">
        <span><%= t('quiz.progress', current: @current_index + 1, total: @total_questions) %></span>
        <span><%= ((@current_index.to_f / @total_questions) * 100).round %>%</span>
      </div>
      <div class="w-full bg-bg3 h-2 rounded-full overflow-hidden">
        <div class="bg-accent h-2 rounded-full transition-all duration-500 ease-out" 
             style="width: <%= ((@current_index.to_f / @total_questions) * 100).round %>%"></div>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-2xl font-bold mb-4">
        <%= I18n.locale == :en ? @question.body_en : @question.body_pt %>
      </h2>
      
      <% if @question.context_pt.present? %>
        <p class="text-gray-600 dark:text-gray-400 italic mb-6">
          <%= I18n.locale == :en ? @question.context_en : @question.context_pt %>
        </p>
      <% end %>

      <% if libras_mode_enabled? && @question.libras_embed_url.present? %>
        <div class="mb-6" data-controller="libras-modal">
          <button type="button" 
                  data-action="click->libras-modal#open"
                  data-video-url="<%= @question.libras_embed_url %>"
                  class="flex items-center space-x-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-4 py-2.5 rounded-lg shadow transition"
                  aria-label="<%= t('quiz.watch_in_libras') %>">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
            </svg>
            <span><%= t('quiz.watch_in_libras') %></span>
          </button>

          <!-- Modal Container -->
          <div data-libras-modal-target="modal" 
               class="fixed inset-0 bg-black/70 backdrop-blur-sm z-50 flex items-center justify-center hidden"
               role="dialog"
               aria-modal="true">
            <div class="bg-white dark:bg-gray-800 rounded-xl max-w-3xl w-full mx-4 overflow-hidden shadow-2xl border border-gray-150 dark:border-gray-700/50">
              <div class="p-4 flex justify-between items-center border-b border-gray-100 dark:border-gray-700/50">
                <h3 class="font-bold text-lg text-gray-850 dark:text-gray-100"><%= t('quiz.libras_mode') %></h3>
                <button type="button" 
                        data-action="click->libras-modal#close"
                        class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 text-sm font-semibold px-3 py-1.5 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700/50 transition">
                  <%= t('quiz.close') %>
                </button>
              </div>
              <div class="aspect-video w-full bg-black">
                <iframe data-libras-modal-target="iframe"
                        src=""
                        class="w-full h-full"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                        title="<%= t('quiz.libras_mode') %>">
                </iframe>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="space-y-4">
      <% @options.each_with_index do |option, index| %>
        <%= button_to answer_quiz_module_path(@module.slug, locale: I18n.locale, option_index: index), 
                      method: :post,
                      class: "w-full text-left p-4 rounded-xl border border-bg3 bg-bg2 text-tx0 hover:bg-bg3 hover:border-accent/40 shadow-sm transition duration-200 cursor-pointer" do %>
          <span class="font-bold mr-2 text-accent"><%= (index + 65).chr %>)</span>
          <%= I18n.locale == :en ? option.text_en : option.text_pt %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
